{
  "name": "quartz-plugin-content-dates",
  "version": "1.0.0",
  "description": "Show a note's created and modified dates (from frontmatter) under the title.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "import": "./dist/components/index.js" }
  },
  "quartz": {
    "name": "content-dates",
    "displayName": "Content Dates",
    "category": "component",
    "version": "1.0.0",
    "defaultOrder": 50,
    "defaultEnabled": true,
    "components": {
      "ContentDates": {
        "displayName": "Content Dates",
        "defaultPosition": "beforeBody",
        "defaultPriority": 20
      }
    }
  }
}
